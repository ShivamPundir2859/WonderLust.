<% layout("/layout/boilerplate.ejs")%>

<div class="container" style="margin-top: 3rem; margin-bottom: 3rem;">
   <div class="row justify-content-center">
      <div class="col-lg-6">
         <div style="background: white; padding: 2.5rem; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.08); text-align: center;">
            <div style="font-size: 3.5rem; margin-bottom: 1.5rem;">
               <i class="fa-solid fa-exclamation-circle" style="color: #e53e3e;"></i>
            </div>
            <h2 style="color: #2d3748; font-weight: 700; margin-bottom: 1rem;">Oops! Something went wrong</h2>
            <p style="font-size: 1.1rem; color: #4a5568; margin-bottom: 2rem;">
               <%= message %>
            </p>
            <a href="/listings" class="btn btn-primary" style="margin-right: 1rem;">
               <i class="fa-solid fa-arrow-left"></i> Back to Listings
            </a>
            <a href="/" class="btn btn-outline-secondary">
               <i class="fa-solid fa-home"></i> Home
            </a>
         </div>
      </div>
   </div>
</div>

<style>
    .btn-outline-secondary {
        border-color: #cbd5e0;
        color: #4a5568;
    }

    .btn-outline-secondary:hover {
        background-color: #edf2f7;
        border-color: #a0aec0;
    }
</style>