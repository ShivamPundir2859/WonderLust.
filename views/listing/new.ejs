<% layout("/layout/boilerplate")%>

<div class="container">
    <div class="row justify-content-center" style="margin-top: 3rem; margin-bottom: 3rem;">
        <div class="col-lg-8">
            <div class="form-section">
                <h3><i class="fa-solid fa-plus-circle"></i> Add New Listing</h3>
                
                <form method="POST" action="/listings" novalidate class="needs-validation" enctype="multipart/form-data">

                    <div class="mb-3">
                        <label for="title" class="form-label">
                            <i class="fa-solid fa-heading"></i> Listing Title
                        </label>
                        <input name="listing[title]" id="title" placeholder="e.g., Cozy Beachfront Cottage" type="text" class="form-control" required>
                        <div class="invalid-feedback">Please provide a title</div>
                    </div>

                    <div class="mb-3">
                        <label for="description" class="form-label">
                            <i class="fa-solid fa-pen"></i> Description
                        </label>
                        <textarea name="listing[description]" id="description" type="text" class="form-control" placeholder="Describe your property in detail..." required></textarea>
                        <div class="invalid-feedback">Please write a description</div>
                    </div>

                    <div class="mb-3">
                        <label for="image" class="form-label">
                            <i class="fa-solid fa-image"></i> Upload Image
                        </label>
                        <input name="listing[image][url]" id="image" type="file" class="form-control">
                        <small class="form-text text-muted">Supported formats: JPG, PNG, GIF (Max 5MB)</small>
                    </div>

                    <div class="row">
                        <div class="mb-3 col-md-6">
                            <label for="price" class="form-label">
                                <i class="fa-solid fa-rupee-sign"></i> Price per Night
                            </label>
                            <input name="listing[price]" id="price" placeholder="e.g., 1500" type="number" class="form-control" required>
                            <div class="invalid-feedback">Please enter a valid price</div>
                        </div>
                        <div class="mb-3 col-md-6">
                            <label for="country" class="form-label">
                                <i class="fa-solid fa-globe"></i> Country
                            </label>
                            <input name="listing[country]" id="country" placeholder="e.g., India" type="text" class="form-control" required>
                            <div class="invalid-feedback">Please enter a country</div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label for="location" class="form-label">
                            <i class="fa-solid fa-map-pin"></i> Location/City
                        </label>
                        <input name="listing[location]" id="location" placeholder="e.g., Mumbai" type="text" class="form-control" required>
                        <div class="invalid-feedback">Please enter a location</div>
                    </div>

                    <div style="display: flex; gap: 1rem;">
                        <button class="btn btn-add">
                            <i class="fa-solid fa-check"></i> Create Listing
                        </button>
                        <a href="/listings" class="btn btn-outline-secondary">
                            <i class="fa-solid fa-times"></i> Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
    .btn-outline-secondary {
        border-color: #cbd5e0;
        color: #4a5568;
    }

    .btn-outline-secondary:hover {
        background-color: #edf2f7;
        border-color: #a0aec0;
    }
</style>