<% layout("/layout/boilerplate") %>

<div class="container">
    <div class="row justify-content-center" style="margin-top: 3rem; margin-bottom: 3rem;">
        <div class="col-lg-8">
            <div class="form-section">
                <h3><i class="fa-solid fa-pen-to-square"></i> Edit Listing</h3>
                
                <form method="POST" action="/listings/<%=listing._id%>?_method=PUT" novalidate class="needs-validation" enctype="multipart/form-data">
                    
                    <div class="mb-3">
                        <label for="title" class="form-label">
                            <i class="fa-solid fa-heading"></i> Listing Title
                        </label>
                        <input name="listing[title]" id="title" value="<%=listing.title%>" class="form-control" type="text" required>
                        <div class="invalid-feedback">Please provide a title</div>
                    </div>

                    <div class="mb-3">
                        <label for="description" class="form-label">
                            <i class="fa-solid fa-pen"></i> Description
                        </label>
                        <textarea name="listing[description]" id="description" class="form-control" required><%=listing.description%></textarea>
                        <div class="invalid-feedback">Please write a description</div>
                    </div>

                    <!-- Image preview -->
                    <div class="mb-3">
                        <label class="form-label"><i class="fa-solid fa-image"></i> Current Image</label>
                        <div style="overflow: hidden; border-radius: 8px; margin-bottom: 1rem;">
                            <img src="<%= listing.image.url %>" class="img-fluid" style="max-height: 250px; width: 100%; object-fit: cover;" alt="Current listing image">
                        </div>
                    </div>

                    <div class="mb-3">
                        <label for="image" class="form-label">
                            <i class="fa-solid fa-upload"></i> Upload New Image
                        </label>
                        <input name="listing[image][url]" id="image" type="file" class="form-control">
                        <small class="form-text text-muted">Leave blank to keep current image</small>
                    </div>

                    <div class="row">
                        <div class="mb-3 col-md-6">
                            <label for="price" class="form-label">
                                <i class="fa-solid fa-rupee-sign"></i> Price per Night
                            </label>
                            <input name="listing[price]" id="price" value="<%=listing.price%>" type="number" class="form-control" required>
                            <div class="invalid-feedback">Please enter a valid price</div>
                        </div>
                        <div class="mb-3 col-md-6">
                            <label for="country" class="form-label">
                                <i class="fa-solid fa-globe"></i> Country
                            </label>
                            <input name="listing[country]" id="country" value="<%=listing.country%>" type="text" class="form-control" required>
                            <div class="invalid-feedback">Please enter a country</div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label for="location" class="form-label">
                            <i class="fa-solid fa-map-pin"></i> Location/City
                        </label>
                        <input name="listing[location]" id="location" value="<%=listing.location%>" type="text" class="form-control" required>
                        <div class="invalid-feedback">Please enter a location</div>
                    </div>

                    <div style="display: flex; gap: 1rem;">
                        <button class="btn btn-add">
                            <i class="fa-solid fa-check"></i> Save Changes
                        </button>
                        <a href="/listings/<%=listing._id%>" class="btn btn-outline-secondary">
                            <i class="fa-solid fa-times"></i> Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
    .btn-outline-secondary {
        border-color: #cbd5e0;
        color: #4a5568;
    }

    .btn-outline-secondary:hover {
        background-color: #edf2f7;
        border-color: #a0aec0;
    }
</style>