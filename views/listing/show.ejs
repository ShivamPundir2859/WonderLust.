<% layout("/layout/boilerplate") %>

<div class="container">
	<div class="row justify-content-center mb-4" style="margin-top: 2rem;">
		<div class="col-lg-8">
			<a href="/listings" class="btn btn-sm btn-outline-secondary mb-3">
				<i class="fa-solid fa-arrow-left"></i> Back to Listings
			</a>
			<h1 class="listing-title"><%= listing.title%></h1>
		</div>
	</div>

	<!-- Image Section -->
	<div class="row justify-content-center mb-4">
		<div class="col-lg-8">
			<div class="show-card" style="padding: 0; overflow: hidden;">
				<img src="<%=listing.image.url%>" class="show-img" alt="listing image" style="width: 100%; border-radius: 12px;">
			</div>
		</div>
	</div>

	<!-- Details Section -->
	<div class="row justify-content-center">
		<div class="col-lg-8">
			<div class="show-card">
				<!-- Price -->
				<div class="price-tag">
					&#8377; <%= listing.price ? listing.price.toLocaleString("en-IN") : "N/A" %> <span style="font-size: 1rem; color: #718096;">per night</span>
				</div>

				<!-- Location Details -->
				<div class="detail-item">
					<span class="detail-label"><i class="fa-solid fa-location-dot"></i> Location</span>
					<span class="detail-value"><%= listing.location%></span>
				</div>

				<div class="detail-item">
					<span class="detail-label"><i class="fa-solid fa-globe"></i> Country</span>
					<span class="detail-value"><%= listing.country%></span>
				</div>

				<!-- Host Info -->
				<div class="detail-item">
					<span class="detail-label"><i class="fa-solid fa-user"></i> Host</span>
					<span class="detail-value"><strong><%= listing.owner.username %></strong></span>
				</div>

				<!-- Description -->
				<div style="margin-top: 2rem; padding-top: 2rem; border-top: 1px solid #e2e8f0;">
					<h4 style="font-weight: 700; color: #2d3748; margin-bottom: 1rem;">About this place</h4>
					<p style="line-height: 1.8; color: #4a5568;">
						<%= listing.description%>
					</p>
				</div>
			</div>

			<!-- Edit/Delete Buttons -->
			<% if(currUser && listing.owner._id.equals(currUser._id)) { %>
				<div class="btns">
					<a href="/listings/<%=listing._id%>/edit" class="btn btn-primary edit-btn">
						<i class="fa-solid fa-pen-to-square"></i> Edit Listing
					</a>
					<form method="POST" action="/listings/<%=listing._id%>?_method=Delete" style="display: inline;">
						<button class="btn btn-danger delete-btn" onclick="return confirm('Are you sure?')">
							<i class="fa-solid fa-trash"></i> Delete Listing
						</button>
					</form>
				</div>
			<% } %>

			<hr />

			<!-- Reviews Section -->
			<div class="rating-section">
				<% if(currUser){ %>
					<h4><i class="fa-solid fa-star"></i> Leave a Review</h4>
					<form action="/listings/<%=listing._id%>/reviews" method="post" novalidate class="needs-validation">
						<div class="mb-3 mt-4">
							<label for="rating" class="form-label">Your Rating: <span style="color: #e53e3e;">*</span></label>
							<fieldset class="starability-slot">
								<input type="radio" id="fifth" name="review[rating]" value="5" />
								<label for="fifth">5 stars</label>
								<input type="radio" id="fourth" name="review[rating]" value="4" />
								<label for="fourth">4 stars</label>
								<input type="radio" id="third" name="review[rating]" value="3" checked />
								<label for="third">3 stars</label>
								<input type="radio" id="second" name="review[rating]" value="2" />
								<label for="second">2 stars</label>
								<input type="radio" id="first" name="review[rating]" value="1" />
								<label for="first">1 star</label>
							</fieldset>
							<div class="invalid-feedback d-block" id="ratingError" style="display: none; color: #e53e3e; font-size: 0.85rem;">Please select a rating</div>
						</div>

						<div class="mb-3">
							<label for="comment" class="form-label">Your Comment: <span style="color: #e53e3e;">*</span></label>
							<textarea name="review[comment]" id="comment" class="form-control" rows="4" required></textarea>
							<div class="invalid-feedback">Please write a comment</div>
						</div>

						<button class="btn btn-primary" type="submit">Submit Review</button>
					</form>
				<% } %>

				<% if(!currUser){ %>
					<div style="text-align: center; padding: 2rem; background: #f0f4ff; border-radius: 8px;">
						<p style="color: #667eea; font-weight: 600; margin-bottom: 1rem;">
							<i class="fa-solid fa-lock"></i> Please sign in to leave a review
						</p>
						<a href="/login" class="btn btn-sm btn-primary">Sign In to Review</a>
					</div>
				<% } %>
			</div>

			<!-- Reviews Display -->
			<div style="margin-top: 3rem;">
				<h4 style="font-weight: 700; color: #2d3748; margin-bottom: 1.5rem;">
					<i class="fa-solid fa-comments"></i> Reviews (<%= listing.reviews.length %>)
				</h4>
				
				<% if(listing.reviews.length === 0) { %>
					<p style="color: #718096; font-style: italic;">No reviews yet. Be the first to review!</p>
				<% } else { %>
					<% for(let review of listing.reviews){ %>
						<div style="background: white; padding: 1.5rem; border-radius: 8px; margin-bottom: 1rem; border-left: 4px solid #667eea;">
							<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.5rem;">
								<strong style="color: #2d3748;"><%= review.author.username %></strong>
								<div class="starability-result" data-rating="<%= review.rating %>"></div>
							</div>
							<p style="margin-bottom: 0.5rem; color: #4a5568;"><%= review.comment %></p>
							<% if(currUser && review.author._id.equals(currUser._id)) { %>
								<form method="POST" action="/listings/<%=listing._id%>/reviews/<%=review._id%>?_method=Delete" style="display: inline;">
									<button class="btn btn-sm btn-danger" onclick="return confirm('Delete this review?')">Delete</button>
								</form>
							<% } %>
						</div>
					<% } %>
				<% } %>
			</div>
		</div>
	</div>
</div>

<style>
    .btn-danger {
        background-color: #e53e3e;
        border: none;
    }

    .btn-danger:hover {
        background-color: #c53030;
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(229, 62, 62, 0.3);
    }

    .btn-outline-secondary {
        border-color: #cbd5e0;
        color: #4a5568;
    }

    .btn-outline-secondary:hover {
        background-color: #edf2f7;
        border-color: #a0aec0;
    }
</style>

<script>
    // Validate review form before submission
    const reviewForm = document.querySelector('.rating-section form');
    if (reviewForm) {
        reviewForm.addEventListener('submit', function(e) {
            const ratingChecked = document.querySelector('input[name="review[rating]"]:checked');
            const ratingError = document.getElementById('ratingError');
            
            if (!ratingChecked) {
                e.preventDefault();
                ratingError.style.display = 'block';
                return false;
            }
            ratingError.style.display = 'none';
        });
    }
</script>
    }
</style>